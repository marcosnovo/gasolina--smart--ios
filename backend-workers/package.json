{
  "name": "gasolina-smart-api-workers",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:create": "wrangler d1 create gasolina-smart-db",
    "db:migrate": "wrangler d1 execute gasolina-smart-db --remote --file=./schema.sql",
    "db:migrate-local": "wrangler d1 execute gasolina-smart-db --local --file=./schema.sql",
    "r2:create": "wrangler r2 bucket create gasolina-smart-snapshots"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.90.0"
  }
}
